{
  "rewrites": [
    {
      "source": "/((?!css/|js/|api/).*)",
      "destination": "/landing.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}